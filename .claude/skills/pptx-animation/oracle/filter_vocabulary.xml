<?xml version="1.0" encoding="UTF-8"?>
<!--
  Animation Oracle — Filter Vocabulary SSOT

  The complete set of <p:animEffect filter="..."> values that PowerPoint
  recognises for entrance and exit effects. Each <filter> element records
  the exact filter string (including any sub-parameter), its canonical
  entrance / exit preset ID mapping, a human description, its current
  verification state, and the provenance of the empirical evidence.

  Consumed by AnimationOracle.filter_vocabulary() for handler-level
  enum validation, by the entr/filter_effect and exit/filter_effect
  slots for token enumeration, and by the README as the source of truth
  for the filter table.

  To add a new filter:
    1. Verify it plays in PowerPoint via .visual_tmp/filter_sweep.py
    2. Add a new <filter> element below with the full filter string,
       preset mappings, description, and verification=visually-verified
    3. Cite the reference file in <source>.
-->
<filter-vocabulary>

  <filter value="fade">
    <description>opacity fade in/out</description>
    <entrance preset-id="9" preset-subtype="0"/>
    <exit preset-id="9" preset-subtype="0"/>
    <verification>visually-verified</verification>
    <source>entr/fade legacy slot + .visual_tmp/filter_sweep.py entrance sweep</source>
  </filter>

  <filter value="dissolve">
    <description>pixel-noise dissolve reveal</description>
    <entrance preset-id="10" preset-subtype="0"/>
    <exit preset-id="10" preset-subtype="0"/>
    <verification>visually-verified</verification>
    <source>.visual_tmp/filter_sweep.py entrance sweep; experiment 7.pptx exit preset 9</source>
  </filter>


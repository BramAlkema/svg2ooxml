<p:par>
    <p:cTn id="{PAR_ID}" dur="{DURATION_MS}" fill="hold" nodeType="clickEffect" grpId="{PAR_ID}" presetID="6" presetClass="emph" presetSubtype="0">
        <p:stCondLst>
            <p:cond delay="{DELAY_MS}"/>
        </p:stCondLst>
        <p:childTnLst>
            <p:animScale>
                <p:cBhvr>
                    <p:cTn id="{BEHAVIOR_ID}" dur="{DURATION_MS}" fill="{INNER_FILL}" nodeType="withEffect">
                        <p:stCondLst>
                            <p:cond delay="0"/>
                        </p:stCondLst>
                    </p:cTn>
                    <p:tgtEl>
                        <p:spTgt spid="{SHAPE_ID}"/>
                    </p:tgtEl>
                </p:cBhvr>
                <p:from x="{FROM_X}" y="{FROM_Y}"/>
                <p:to x="{TO_X}" y="{TO_Y}"/>
            </p:animScale>
        </p:childTnLst>
    </p:cTn>
</p:par>

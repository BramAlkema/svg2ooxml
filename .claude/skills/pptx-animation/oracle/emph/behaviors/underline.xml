<fragment>
    <p:set>
        <p:cBhvr override="childStyle">
            <p:cTn id="{BEHAVIOR_ID}" dur="500" fill="hold"/>
            <p:tgtEl>
                <p:spTgt spid="{SHAPE_ID}">
                    <p:txEl>
                        <p:pRg st="0" end="0"/>
                    </p:txEl>
                </p:spTgt>
            </p:tgtEl>
            <p:attrNameLst>
                <p:attrName>style.textDecorationUnderline</p:attrName>
            </p:attrNameLst>
        </p:cBhvr>
        <p:to>
            <p:strVal val="true"/>
        </p:to>
    </p:set>
</fragment>

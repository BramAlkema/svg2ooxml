<p:par>
    <p:cTn id="{PAR_ID}" dur="{DURATION_MS}" fill="hold" nodeType="clickEffect" grpId="{PAR_ID}" presetID="15" presetClass="emph" presetSubtype="0">
        <p:stCondLst>
            <p:cond delay="{DELAY_MS}"/>
        </p:stCondLst>
        <p:iterate type="lt">
            <p:tmAbs val="25"/>
        </p:iterate>
        <p:childTnLst>
            <p:set>
                <p:cBhvr override="childStyle">
                    <p:cTn id="{BEHAVIOR_ID}" dur="indefinite"/>
                    <p:tgtEl>
                        <p:spTgt spid="{SHAPE_ID}">
                            <p:txEl>
                                <p:pRg st="0" end="0"/>
                            </p:txEl>
                        </p:spTgt>
                    </p:tgtEl>
                    <p:attrNameLst>
                        <p:attrName>style.fontWeight</p:attrName>
                    </p:attrNameLst>
                </p:cBhvr>
                <p:to>
                    <p:strVal val="bold"/>
                </p:to>
            </p:set>
        </p:childTnLst>
    </p:cTn>
</p:par>

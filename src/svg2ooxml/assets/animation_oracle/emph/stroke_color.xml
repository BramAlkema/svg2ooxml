<p:par>
    <p:cTn id="{PAR_ID}" dur="{DURATION_MS}" fill="hold" nodeType="clickEffect" grpId="{PAR_ID}" presetID="7" presetClass="emph" presetSubtype="2">
        <p:stCondLst>
            <p:cond delay="{DELAY_MS}"/>
        </p:stCondLst>
        <p:childTnLst>
            <p:animClr clrSpc="rgb" dir="cw">
                <p:cBhvr>
                    <p:cTn id="{CLR_BEHAVIOR_ID}" dur="{DURATION_MS}" fill="{INNER_FILL}"/>
                    <p:tgtEl>
                        <p:spTgt spid="{SHAPE_ID}"/>
                    </p:tgtEl>
                    <p:attrNameLst>
                        <p:attrName>stroke.color</p:attrName>
                    </p:attrNameLst>
                </p:cBhvr>
                <p:to>
                    <a:srgbClr val="{TO_COLOR}"/>
                </p:to>
            </p:animClr>
            <p:set>
                <p:cBhvr>
                    <p:cTn id="{SET_BEHAVIOR_ID}" dur="{DURATION_MS}" fill="{INNER_FILL}"/>
                    <p:tgtEl>
                        <p:spTgt spid="{SHAPE_ID}"/>
                    </p:tgtEl>
                    <p:attrNameLst>
                        <p:attrName>stroke.on</p:attrName>
                    </p:attrNameLst>
                </p:cBhvr>
                <p:to>
                    <p:strVal val="true"/>
                </p:to>
            </p:set>
        </p:childTnLst>
    </p:cTn>
</p:par>

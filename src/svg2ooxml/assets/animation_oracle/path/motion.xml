<p:par>
    <p:cTn id="{PAR_ID}" dur="{DURATION_MS}" fill="hold" nodeType="{NODE_TYPE}" grpId="{PAR_ID}" presetClass="path">
        <p:stCondLst>
            <p:cond delay="{DELAY_MS}"/>
        </p:stCondLst>
        <p:childTnLst>
            <p:animMotion origin="layout" path="{PATH_DATA}" pathEditMode="relative">
                <p:cBhvr>
                    <p:cTn id="{BEHAVIOR_ID}" dur="{DURATION_MS}" fill="{INNER_FILL}" nodeType="withEffect">
                        <p:stCondLst>
                            <p:cond delay="0"/>
                        </p:stCondLst>
                    </p:cTn>
                    <p:tgtEl>
                        <p:spTgt spid="{SHAPE_ID}"/>
                    </p:tgtEl>
                </p:cBhvr>
            </p:animMotion>
        </p:childTnLst>
    </p:cTn>
</p:par>

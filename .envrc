# direnv config for svg2ooxml
export VIRTUAL_ENV=.venv
layout python python3.11

# Auto-install dev deps when requirements-dev.txt changes
export PIP_REQUIRE_VIRTUALENV=true
REQ_FILE="requirements-dev.txt"
REQ_HASH_FILE="$VIRTUAL_ENV/.requirements-dev.sha256"
if [[ -f "$REQ_FILE" ]]; then
  REQ_HASH=$(shasum -a 256 "$REQ_FILE" | awk '{print $1}')
  if [[ ! -f "$REQ_HASH_FILE" ]] || [[ "$REQ_HASH" != "$(cat "$REQ_HASH_FILE")" ]]; then
    log_status "Installing Python deps from $REQ_FILE"
    "$VIRTUAL_ENV/bin/python" -m pip install --upgrade pip setuptools wheel
    "$VIRTUAL_ENV/bin/pip" install -r "$REQ_FILE"
    echo "$REQ_HASH" > "$REQ_HASH_FILE"
  fi
fi

# GitHub CLI default repo
export GH_REPO="BramAlkema/svg2ooxml"

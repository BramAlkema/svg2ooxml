rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection - users can only read their own data
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only backend can write via Admin SDK
    }

    // Subscriptions - users can only read their own subscriptions
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() &&
                     resource.data.userId == request.auth.uid;
      allow write: if false; // Only backend can write via Admin SDK
    }

    // Usage tracking - users can only read their own usage
    match /usage/{usageId} {
      allow read: if isAuthenticated() &&
                     resource.data.userId == request.auth.uid;
      allow write: if false; // Only backend can write via Admin SDK
    }

    // Webhook events - completely private (backend only)
    match /webhook_events/{eventId} {
      allow read, write: if false; // Only backend via Admin SDK
    }

    // Export jobs - users can read their own jobs
    match /exports/{jobId} {
      allow read: if isAuthenticated() &&
                     resource.data.user.uid == request.auth.uid;
      allow write: if false; // Only backend can write via Admin SDK

      // SVG subcollection
      match /svgs/{svgId} {
        allow read: if isAuthenticated() &&
                       get(/databases/$(database)/documents/exports/$(jobId)).data.user.uid == request.auth.uid;
        allow write: if false;
      }
    }

    // Font cache - read-only for all authenticated users
    match /font_cache/{fontId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only backend can write via Admin SDK
    }

    // Conversion cache - read-only for all authenticated users
    match /conversion_cache/{cacheId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only backend can write via Admin SDK
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
